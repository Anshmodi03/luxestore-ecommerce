# ── Server ──
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# ── MongoDB ──
MONGODB_URI=mongodb://localhost:27017/luxestore
# Atlas: mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/luxestore?retryWrites=true&w=majority

# ── Firebase (JWT verification — no service account needed) ──
# Omit to run in dev mode (accepts X-Dev-User-Id header instead of real JWT)
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret  (optional, for webhooks)
